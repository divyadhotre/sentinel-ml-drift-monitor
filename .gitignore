__pycache__/
*.pyc
.ipynb_checkpoints/
venv/
.venv/
*.egg-info/
.DS_Store

# Raw data files (large, download via README instructions instead)
data/raw/*.parquet
data/raw/*.csv
data/processed/*.csv
